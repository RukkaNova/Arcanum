---
// Lite YouTube facade — zero iframe / zero third-party JS on load, so it does
// NOT affect Lighthouse/PageSpeed. The real player is injected only on click.
interface Props {
  id: string;        // YouTube video id
  poster: string;    // local poster image path (e.g. /img/foo.webp)
  title: string;     // accessible label + img alt
  caption?: string;  // optional visible caption under the player
}
const { id, poster, title, caption } = Astro.props;
---
<figure class="ytf-fig">
  <button class="ytf" data-ytid={id} type="button" aria-label={`Play video: ${title}`}>
    <img class="ytf-poster" src={poster} alt={title} width="1280" height="720" loading="eager" decoding="async" />
    <span class="ytf-play" aria-hidden="true">
      <svg viewBox="0 0 68 48" width="68" height="48">
        <path class="ytf-pbg" d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"/>
        <path d="M45 24 27 14v20z" fill="#fff"/>
      </svg>
    </span>
  </button>
  {caption && <figcaption class="ytf-cap mono">{caption}</figcaption>}
</figure>

<script>
  // One delegated listener handles every facade on the page.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('.ytf') as HTMLElement | null;
    if (!btn) return;
    const id = btn.getAttribute('data-ytid');
    if (!id) return;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
    iframe.title = btn.getAttribute('aria-label') || 'YouTube video';
    iframe.className = 'ytf-frame';
    iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
    iframe.setAttribute('allowfullscreen', '');
    btn.replaceWith(iframe);
  });
</script>

<style>
  .ytf-fig { margin: 1.8rem 0; }
  .ytf {
    display: block; position: relative; width: 100%; padding: 0; border: 1px solid var(--line);
    border-radius: 12px; overflow: hidden; background: var(--ink-2); cursor: pointer; aspect-ratio: 16 / 9;
  }
  .ytf-poster { display: block; width: 100%; height: 100%; object-fit: cover; }
  .ytf-play {
    position: absolute; inset: 0; margin: auto; width: 68px; height: 48px;
    display: flex; align-items: center; justify-content: center; opacity: .9; transition: transform .15s, opacity .15s;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,.45));
  }
  .ytf-pbg { fill: #1a1a1a; opacity: .82; transition: fill .15s, opacity .15s; }
  .ytf:hover .ytf-play, .ytf:focus-visible .ytf-play { transform: scale(1.08); opacity: 1; }
  .ytf:hover .ytf-pbg, .ytf:focus-visible .ytf-pbg { fill: #cc2b1d; opacity: 1; }
  .ytf:focus-visible { outline: 2px solid var(--ember); outline-offset: 2px; }
  .ytf-frame { display: block; width: 100%; aspect-ratio: 16 / 9; border: 1px solid var(--line); border-radius: 12px; }
  .ytf-cap { margin-top: .6rem; font-size: .78rem; color: var(--rune); text-align: center; letter-spacing: .03em; }
</style>
