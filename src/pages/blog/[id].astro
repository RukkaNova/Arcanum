---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
export async function getStaticPaths(){
  const posts=await getCollection('blog');
  return posts.map(p=>({params:{id:p.id},props:{post:p}}));
}
const { post }=Astro.props; const { Content }=await render(post); const d=post.data;
const dateModified=(d.updatedDate??d.pubDate).toISOString();
const isPlatformReview=d.section==='platform-reviews';
// Own products (Arcanum Originals carry a releaseSlug) must NOT emit self-serving
// Review/rating structured data — against Google review-snippet guidelines.
const isOwnProduct=!!d.releaseSlug;
const isGameReview=d.section==='reviews'&&!isOwnProduct;
const isReview=(isPlatformReview||isGameReview)&&d.rating;
const extractSubject=(t)=>t.includes(' Review')?t.split(' Review')[0].trim():t.includes(':')?t.split(':')[0].trim():t;
const reviewSubject=isReview?extractSubject(d.title):null;
const author={'@type':'Person',name:'Rukka',url:'https://arcanumrpgs.com/about'};
const jsonLd=isReview
  ?{'@context':'https://schema.org','@type':'Review',headline:d.title,description:d.description,datePublished:d.pubDate.toISOString(),dateModified,author,reviewRating:{'@type':'Rating',ratingValue:d.rating,bestRating:5,worstRating:1},itemReviewed:{'@type':isPlatformReview?'SoftwareApplication':'VideoGame',name:reviewSubject,...(isPlatformReview&&{applicationCategory:'GameApplication'})}}
  :{'@context':'https://schema.org','@type':'Article',headline:d.title,description:d.description,datePublished:d.pubDate.toISOString(),dateModified,author};
const displayDate=d.pubDate.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
const updatedDisplay=d.updatedDate?d.updatedDate.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}):null;
---
<Base title={`${d.title} | Arcanum`} description={d.description} type="article" jsonLd={jsonLd}>
  <article class="wrap post">
    <a class="back mono" href="/blog">← Codex</a>
    <h1>{d.title}</h1>
    <div class="byline">
      <time class="mono" datetime={d.pubDate.toISOString()}>{displayDate}</time>
      <span class="sep">·</span>
      <span class="author mono">by <a href="/about">Rukka</a></span>
      {updatedDisplay && <><span class="sep">·</span><span class="updated mono">Updated {updatedDisplay}</span></>}
    </div>
    <div class="prose"><Content/></div>
    {d.releaseSlug && (
      <div class="dl-cta">
        <a class="dl-btn" href={`/arcanum-games/${d.releaseSlug}`}>↓ Download free — get the files</a>
      </div>
    )}
  </article>
  <style>
    .post{padding:2.5rem 1.25rem 3rem;max-width:720px;}
    .back{color:var(--parchment-dim);font-size:.8rem;}
    h1{font-size:clamp(2rem,5vw,3rem);font-weight:600;line-height:1.08;margin:1.2rem 0 .5rem;}
    .byline{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.2rem;}
    .byline time,.byline .author,.byline .updated{color:var(--rune);font-size:.8rem;}
    .byline .sep{color:var(--line);font-size:.8rem;}
    .byline .author a{color:var(--rune);}
    .byline .author a:hover{color:var(--ember);text-decoration:none;}
    .prose{margin-top:2rem;}
    .prose :global(p){margin-bottom:1rem;}
    .dl-cta{margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--line);}
    .dl-btn{font-family:var(--mono);font-size:.9rem;background:var(--ember);color:var(--ink);padding:.8rem 1.6rem;border-radius:7px;font-weight:600;display:inline-block;}
    .dl-btn:hover{text-decoration:none;filter:brightness(1.08);}
  </style>
</Base>
