---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import VideoFacade from '../../components/VideoFacade.astro';
export async function getStaticPaths(){
  const posts=await getCollection('blog');
  return posts.map(p=>({params:{id:p.id},props:{post:p}}));
}
const { post }=Astro.props; const { Content, headings }=await render(post); const d=post.data;
const toc=headings.filter(h=>h.depth===2);
const showToc=toc.length>=4;
const dateModified=(d.updatedDate??d.pubDate).toISOString();
const isPlatformReview=d.section==='platform-reviews';
// Own products (Arcanum Originals carry a releaseSlug) must NOT emit self-serving
// Review/rating structured data — against Google review-snippet guidelines.
const isOwnProduct=!!d.releaseSlug;
const isGameReview=d.section==='reviews'&&!isOwnProduct;
const isReview=(isPlatformReview||isGameReview)&&d.rating;
const extractSubject=(t)=>t.includes(' Review')?t.split(' Review')[0].trim():t.includes(':')?t.split(':')[0].trim():t;
const reviewSubject=isReview?extractSubject(d.title):null;
const author={'@type':'Person',name:'Rukka',url:'https://arcanumrpgs.com/about'};
const baseLd=isReview
  ?{'@context':'https://schema.org','@type':'Review',headline:d.title,description:d.description,datePublished:d.pubDate.toISOString(),dateModified,author,reviewRating:{'@type':'Rating',ratingValue:d.rating,bestRating:5,worstRating:1},itemReviewed:{'@type':isPlatformReview?'SoftwareApplication':'VideoGame',name:reviewSubject,...(isPlatformReview&&{applicationCategory:'GameApplication'})}}
  :{'@context':'https://schema.org','@type':'Article',headline:d.title,description:d.description,datePublished:d.pubDate.toISOString(),dateModified,author};
// Optional FAQPage block (frontmatter `faq`). Answers must mirror visible page text.
const faqLd=d.faq?.length
  ?{'@context':'https://schema.org','@type':'FAQPage',mainEntity:d.faq.map(f=>({'@type':'Question',name:f.q,acceptedAnswer:{'@type':'Answer',text:f.a}}))}
  :null;
// Optional VideoObject (frontmatter `video`) — emits rich-result-eligible structured data.
const ORIGIN='https://arcanumrpgs.com';
const videoLd=d.video
  ?{'@context':'https://schema.org','@type':'VideoObject',name:d.video.title,description:d.video.description??d.description,thumbnailUrl:[ORIGIN+d.video.poster],uploadDate:(d.video.uploadDate??d.pubDate).toISOString(),...(d.video.duration&&{duration:d.video.duration}),embedUrl:`https://www.youtube.com/embed/${d.video.id}`,contentUrl:`https://youtu.be/${d.video.id}`}
  :null;
// Optional ItemList block (frontmatter `itemList`) — for directory/list pages.
const itemListLd=d.itemList?.length
  ?{'@context':'https://schema.org','@type':'ItemList',itemListElement:d.itemList.map((it,i)=>({'@type':'ListItem',position:i+1,name:it.name,...(it.url&&{url:ORIGIN+it.url}),...(it.description&&{description:it.description})}))}
  :null;
const ldBlocks=[baseLd,faqLd,videoLd,itemListLd].filter(Boolean);
const jsonLd=ldBlocks.length>1?ldBlocks:ldBlocks[0];
const fmtDur=(iso)=>{const m=iso?.match(/PT(?:(\d+)M)?(?:(\d+)S)?/);if(!m)return null;return `${+(m[1]||0)}:${String(+(m[2]||0)).padStart(2,'0')}`;};
const videoCaption=d.video?(d.video.duration?`Video review · ${fmtDur(d.video.duration)}`:'Video review'):null;
const displayDate=d.pubDate.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
const updatedDisplay=d.updatedDate?d.updatedDate.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}):null;
---
<Base title={`${d.title} | Arcanum`} description={d.description} type="article" jsonLd={jsonLd}>
  <article class="wrap post">
    <a class="back mono" href="/blog">← Codex</a>
    <h1>{d.title}</h1>
    <div class="byline">
      <time class="mono" datetime={d.pubDate.toISOString()}>{displayDate}</time>
      <span class="sep">·</span>
      <span class="author mono">by <a href="/about">Rukka</a></span>
      {updatedDisplay && <><span class="sep">·</span><span class="updated mono">Updated {updatedDisplay}</span></>}
    </div>
    {d.video && <VideoFacade id={d.video.id} poster={d.video.poster} title={d.video.title} caption={videoCaption} />}
    {showToc && (
      <nav class="toc" aria-label="Table of contents">
        <p class="toc-label mono">On this page</p>
        <ol>
          {toc.map(h => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
        </ol>
      </nav>
    )}
    <div class="prose"><Content/></div>
    {d.releaseSlug && (
      <div class="dl-cta">
        <a class="dl-btn" href={`/arcanum-games/${d.releaseSlug}`}>↓ Download free — get the files</a>
      </div>
    )}
  </article>
  <style>
    .post{padding:2.5rem 1.25rem 3rem;max-width:720px;}
    .back{color:var(--parchment-dim);font-size:.8rem;}
    h1{font-size:clamp(2rem,5vw,3rem);font-weight:600;line-height:1.08;margin:1.2rem 0 .5rem;}
    .byline{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.2rem;}
    .byline time,.byline .author,.byline .updated{color:var(--rune);font-size:.8rem;}
    .byline .sep{color:var(--line);font-size:.8rem;}
    .byline .author a{color:var(--rune);}
    .byline .author a:hover{color:var(--ember);text-decoration:none;}
    .toc{margin-top:2rem;border:1px solid var(--line);border-radius:10px;background:var(--ink-2);padding:1.1rem 1.3rem;}
    .toc-label{color:var(--rune);font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;margin-bottom:.7rem;}
    .toc ol{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:.45rem;counter-reset:toc;}
    .toc li{counter-increment:toc;}
    .toc a{color:var(--parchment-dim);font-size:.92rem;}
    .toc a::before{content:counter(toc,decimal-leading-zero);color:var(--rune);font-family:var(--mono);font-size:.72rem;margin-right:.6rem;}
    .toc a:hover{color:var(--ember);text-decoration:none;}
    .prose{margin-top:2rem;}
    .prose :global(p){margin-bottom:1rem;}
    .dl-cta{margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--line);}
    .dl-btn{font-family:var(--mono);font-size:.9rem;background:var(--ember);color:var(--ink);padding:.8rem 1.6rem;border-radius:7px;font-weight:600;display:inline-block;}
    .dl-btn:hover{text-decoration:none;filter:brightness(1.08);}
  </style>
</Base>
