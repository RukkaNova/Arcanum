---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
const SECTIONS={news:'Arcanum News',reviews:'Game Reviews','platform-reviews':'Platform Reviews',articles:'Articles',guides:'Guides & How-Tos',lists:'Lists'};
const posts=(await getCollection('blog')).filter(p=>!p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const bySection=Object.keys(SECTIONS).map(s=>({key:s,label:SECTIONS[s],items:posts.filter(p=>p.data.section===s)})).filter(g=>g.items.length);
const fmt=(d)=>d.toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'});
---
<Base title="The Codex — LLM RPG Guides, Reviews & Lists | Arcanum" description="Guides, game reviews, platform reviews and lists for LLM roleplay. Learn to run better AI campaigns and find the best games and clients.">
  <div class="wrap codex">
    <h1>The Codex</h1>
    <p class="sub">Reviews, guides, and field notes for LLM roleplay.</p>
    <p class="method">All reviews are the independent assessment of <a href="/about">Rukka</a> — four decades across tabletop RPGs, CRPGs, MMOs, and AI roleplay systems. Game and platform ratings reflect mechanical depth, long-campaign stability, and value for the player's time, scored out of 5.</p>
    <nav class="jump" aria-label="Codex sections">
      {bySection.map(g=>(
        <a class="mono" href={`#${g.key}`}>{g.label} <span class="count">{g.items.length}</span></a>
      ))}
    </nav>
    {bySection.map(g=>(
      <section class="sec" id={g.key}>
        <h2 class="mono">{g.label}</h2>
        <ul class="posts">
          {g.items.map(p=>(
            <li><a href={`/blog/${p.id}`}><time class="mono">{fmt(p.data.pubDate)}</time><h3>{p.data.title}</h3><p>{p.data.description}</p></a></li>
          ))}
        </ul>
      </section>
    ))}
  </div>
  <style>
    .codex{padding:3rem 1.25rem;max-width:820px;}
    h1{font-size:clamp(2rem,5vw,3rem);font-weight:600;}
    .sub{color:var(--parchment-dim);margin:.5rem 0 .8rem;}
    .method{font-family:var(--mono);font-size:.78rem;color:var(--rune);line-height:1.6;margin-bottom:2.2rem;max-width:620px;}
    .method a{color:var(--rune);text-decoration:underline;text-underline-offset:2px;}
    .method a:hover{color:var(--ember);}
    .jump{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2.4rem;}
    .jump a{font-size:.78rem;letter-spacing:.04em;color:var(--parchment-dim);border:1px solid var(--line);border-radius:6px;padding:.35rem .7rem;background:var(--ink-2);transition:border-color .15s,color .15s;}
    .jump a:hover{border-color:var(--ember);color:var(--ember);text-decoration:none;}
    .jump .count{color:var(--rune);margin-left:.25rem;}
    .sec{margin-bottom:2.6rem;scroll-margin-top:4.5rem;}
    .sec h2{font-family:var(--serif);font-size:.8rem;text-transform:uppercase;letter-spacing:.12em;color:var(--ember);border-bottom:1px solid var(--line);padding-bottom:.6rem;margin-bottom:1.1rem;}
    .posts{list-style:none;display:flex;flex-direction:column;gap:1rem;}
    .posts a{display:block;border:1px solid var(--line);border-radius:10px;padding:1.1rem 1.3rem;background:var(--ink-2);color:var(--parchment);transition:border-color .18s;}
    .posts a:hover{border-color:var(--ember);text-decoration:none;}
    .posts time{color:var(--rune);font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;}
    .posts h3{font-size:1.25rem;font-weight:600;margin:.3rem 0 .4rem;}
    .posts p{color:var(--parchment-dim);font-size:.92rem;}
  </style>
</Base>
