---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
const SECTIONS={news:'Arcanum News',reviews:'Game Reviews','platform-reviews':'Platform Reviews',articles:'Articles',guides:'Guides & How-Tos',lists:'Lists'};
const posts=(await getCollection('blog')).filter(p=>!p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const bySection=Object.keys(SECTIONS).map(s=>({key:s,label:SECTIONS[s],items:posts.filter(p=>p.data.section===s)})).filter(g=>g.items.length);
const fmt=(d)=>d.toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'});
---
<Base title="The Codex — LLM RPG Guides, Reviews & Lists | Arcanum" description="Guides, game reviews, platform reviews and lists for LLM roleplay. Learn to run better AI campaigns and find the best games and clients.">
  <div class="wrap codex">
    <h1>The Codex</h1>
    <p class="sub">Reviews, guides, and field notes for LLM roleplay.</p>
    {bySection.map(g=>(
      <section class="sec">
        <h2 class="mono">{g.label}</h2>
        <ul class="posts">
          {g.items.map(p=>(
            <li><a href={`/blog/${p.id}`}><time class="mono">{fmt(p.data.pubDate)}</time><h3>{p.data.title}</h3><p>{p.data.description}</p></a></li>
          ))}
        </ul>
      </section>
    ))}
  </div>
  <style>
    .codex{padding:3rem 1.25rem;max-width:820px;}
    h1{font-size:clamp(2rem,5vw,3rem);font-weight:600;}
    .sub{color:var(--parchment-dim);margin:.5rem 0 2.5rem;}
    .sec{margin-bottom:2.6rem;}
    .sec h2{font-size:.8rem;text-transform:uppercase;letter-spacing:.12em;color:var(--ember);border-bottom:1px solid var(--line);padding-bottom:.6rem;margin-bottom:1.1rem;}
    .posts{list-style:none;display:flex;flex-direction:column;gap:1rem;}
    .posts a{display:block;border:1px solid var(--line);border-radius:10px;padding:1.1rem 1.3rem;background:var(--ink-2);color:var(--parchment);transition:border-color .18s;}
    .posts a:hover{border-color:var(--ember);text-decoration:none;}
    .posts time{color:var(--rune);font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;}
    .posts h3{font-size:1.25rem;font-weight:600;margin:.3rem 0 .4rem;}
    .posts p{color:var(--parchment-dim);font-size:.92rem;}
  </style>
</Base>
