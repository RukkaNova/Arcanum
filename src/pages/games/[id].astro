---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { modelLabel } from '../../platforms';
export async function getStaticPaths(){
  const games=await getCollection('games');
  return games.map(g=>({params:{id:g.id},props:{game:g}}));
}
const { game }=Astro.props; const { Content }=await render(game); const d=game.data;
const stars=d.rating?'★'.repeat(Math.round(d.rating))+'☆'.repeat(5-Math.round(d.rating)):'';
// Don't emit self-serving rating structured data for Arcanum's own games (Originals
// have author 'Arcanum' / a releaseSlug). Third-party games may still carry it.
const isOwnProduct=d.author==='Arcanum'||!!d.releaseSlug;
const jsonLd={'@context':'https://schema.org','@type':'Game',name:d.title,description:d.tagline,genre:d.genres,gamePlatform:modelLabel(d.model),...(d.rating&&!isOwnProduct&&{aggregateRating:{'@type':'AggregateRating',ratingValue:d.rating,ratingCount:1,bestRating:5}})};
---
<Base title={`${d.title} — ${modelLabel(d.model)} RPG | Arcanum`} description={d.tagline} type="article" jsonLd={jsonLd}>
  <article class="wrap game">
    <a class="back mono" href="/games">← all games</a>
    {d.cover && <div class="hero-img"><img src={d.cover} alt={d.title} width="800" height="450"/></div>}
    <div class="badges">
      <span class="token is-platform">{modelLabel(d.model)}</span>
      {d.rating && <span class="rating mono">{stars} {d.rating}/5</span>}
      {d.nsfw && <span class="token">18+</span>}
    </div>
    <h1>{d.title}</h1>
    <p class="tagline">{d.tagline}</p>
    <div class="meta mono"><span>{d.genres.join(' · ')}</span><span>·</span><span>by {d.author}</span><span>·</span><span>Last reviewed: {d.updated.toLocaleDateString('en-US',{year:'numeric',month:'long'})}</span></div>
    <div class="actions">
      {d.playUrl && <a class="launch" href={d.playUrl} target="_blank" rel="noopener">Play on {modelLabel(d.model)} ↗</a>}
      {d.releaseSlug && <a class="download" href={`/arcanum-games/${d.releaseSlug}`}>↓ Download free</a>}
      {d.reviewSlug && <a class="review" href={`/blog/${d.reviewSlug}`}>Read our review →</a>}
    </div>
    <div class="prose"><Content/></div>
  </article>
  <style>
    .game{padding:2rem 1.25rem 3rem;max-width:760px;}
    .back{color:var(--parchment-dim);font-size:.8rem;}
    .hero-img{margin:1.4rem 0;border:1px solid var(--line);border-radius:12px;overflow:hidden;aspect-ratio:16/9;}
    .hero-img img{width:100%;height:100%;object-fit:cover;display:block;}
    .badges{display:flex;gap:.6rem;align-items:center;margin:.6rem 0 1rem;flex-wrap:wrap;}
    .rating{color:var(--gild);font-size:.85rem;}
    h1{font-size:clamp(2.2rem,5vw,3.2rem);font-weight:600;line-height:1.05;}
    .tagline{font-size:1.2rem;color:var(--parchment-dim);font-style:italic;margin:.7rem 0 1rem;}
    .meta{font-size:.8rem;color:var(--rune);display:flex;gap:.6rem;flex-wrap:wrap;}
    .actions{display:flex;gap:1rem;flex-wrap:wrap;margin:1.8rem 0;}
    .launch{font-family:var(--mono);font-size:.85rem;background:var(--ember);color:var(--ink);padding:.7rem 1.3rem;border-radius:7px;font-weight:600;}
    .download{font-family:var(--mono);font-size:.85rem;background:var(--ember);color:var(--ink);padding:.7rem 1.3rem;border-radius:7px;font-weight:600;}
    .launch:hover{text-decoration:none;filter:brightness(1.08);}
    .review{font-family:var(--mono);font-size:.85rem;border:1px solid var(--line);color:var(--parchment);padding:.7rem 1.3rem;border-radius:7px;}
    .review:hover{border-color:var(--ember);color:var(--ember);text-decoration:none;}
    .prose{margin-top:1.5rem;border-top:1px solid var(--line);padding-top:1.8rem;}
    .prose :global(p){margin-bottom:1rem;}
  </style>
</Base>
