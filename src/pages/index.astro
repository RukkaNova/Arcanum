---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const games = await getCollection('games');
const clients = await getCollection('clients');
const releases = await getCollection('releases');

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'WebSite', name: 'Arcanum',
  description: 'The home base for LLM roleplay: discover the best public AI RPGs, compare roleplay platforms, and download original Arcanum game engines for ChatGPT, Claude, and Gemini.',
  url: 'https://arcanumrpgs.com',
};
---
<Base
  title="Arcanum — The home base for LLM roleplay games"
  description="Discover the best AI RPGs for ChatGPT, Claude and Gemini. Compare roleplay platforms and download original Arcanum game engines. The home base for LLM roleplay."
  jsonLd={jsonLd}
>
  <section class="hero wrap">
    <p class="eyebrow mono">// the home base for LLM roleplay</p>
    <h1>Every world worth<br/>playing, in one place.</h1>
    <p class="lede">
      Arcanum is the dedicated home for LLM roleplay games. Find the best public RPGs for
      your AI, see which roleplay platforms are actually worth it, and download our own
      original game engines — built for players who want more than a chat box.
    </p>
    <div class="cta-row">
      <a class="btn" href="/arcanum-games">Arcanum Originals</a>
      <a class="btn ghost" href="/games">Browse all games</a>
    </div>
  </section>

  <section class="wrap featured">
    <p class="feat-eyebrow mono">// featured release</p>
    <div class="feat-card">
      <div class="feat-img">
        <img src="/img/aevum.webp" alt="Aevum Realm Architect" width="480" height="270" fetchpriority="high"/>
      </div>
      <div class="feat-body">
        <div class="feat-badges">
          <span class="token">GPT</span>
          <span class="token">CLA</span>
          <span class="token">GEM</span>
        </div>
        <h2 class="feat-title">Aevum Realm Architect</h2>
        <p class="feat-tagline">Rise from serf to sovereign in a deterministic kingdom-builder — the most ambitious AI RPG engine we've made.</p>
        <p class="feat-desc">Deep, complex, and demanding. Not for the impatient — but nothing else comes close.</p>
        <div class="feat-actions">
          <a class="btn" href="/arcanum-games/aevum/">Download free →</a>
          <a class="btn ghost" href="/blog/aevum-realm-architect/">Read the review →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="wrap pillars">
    <article class="pillar">
      <span class="pnum mono">01</span>
      <h2>Public Games</h2>
      <p>The best AI RPGs you can play right now — published GPTs, Gems, and Claude
      projects — rated and sorted by model and genre.</p>
      <a href="/games" class="plink mono">{games.length} games →</a>
    </article>
    <article class="pillar">
      <span class="pnum mono">02</span>
      <h2>Clients</h2>
      <p>Janitor, Friends &amp; Fables, AI Dungeon and the rest — honest reviews of every
      roleplay platform, so you know what's worth your time.</p>
      <a href="/clients" class="plink mono">{clients.length} clients →</a>
    </article>
    <article class="pillar accent">
      <span class="pnum mono">03</span>
      <h2>Arcanum Originals</h2>
      <p>Our own packaged game engines — download the files, drop them into your AI, and
      play worlds you won't find anywhere else.</p>
      <a href="/arcanum-games" class="plink mono">{releases.length} originals →</a>
    </article>
  </section>

  <section class="wrap about-strip">
    <p>Arcanum is the only site dedicated entirely to LLM roleplay — the art of turning ChatGPT, Claude, and Gemini into genuine game masters rather than chat partners. We find the best public AI RPGs worth your time, review every major roleplay platform honestly, and build our own original game engines that solve the problems every long AI campaign eventually hits: memory drift, passive NPCs, and worlds that stop feeling real around turn fifty.</p>
    <p>Everything we build is free to download. The games run on the AI you already use. No new apps, no new accounts, no subscriptions beyond what you already pay. If you want to know what your AI is actually capable of as a storytelling engine, you are in the right place.</p>
  </section>

  <style>
    .hero { padding: 5rem 1.25rem 3rem; max-width: 860px; }
    .eyebrow { color: var(--rune); font-size: .8rem; letter-spacing: .05em; margin-bottom: 1.4rem; }
    h1 { font-size: clamp(2.4rem, 6vw, 4rem); line-height: 1.03; font-weight: 600; letter-spacing: -.015em; margin-bottom: 1.4rem; }
    .lede { font-size: 1.2rem; color: var(--parchment-dim); max-width: 38rem; margin-bottom: 2rem; }
    .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn { font-family: var(--mono); font-size: .85rem; letter-spacing: .04em; text-transform: uppercase; background: var(--ember); color: var(--ink); padding: .75rem 1.4rem; border-radius: 7px; font-weight: 600; }
    .btn:hover { text-decoration: none; filter: brightness(1.08); }
    .btn.ghost { background: transparent; color: var(--parchment); border: 1px solid var(--line); }
    .btn.ghost:hover { border-color: var(--ember); color: var(--ember); }
    .featured { padding-bottom: 2.5rem; }
    .feat-eyebrow { color: var(--rune); font-size: .8rem; letter-spacing: .05em; margin-bottom: 1rem; }
    .feat-card { display: grid; grid-template-columns: 2fr 3fr; border: 1px solid var(--ember-soft); border-radius: 12px; background: var(--ink-2); overflow: hidden; }
    .feat-img { overflow: hidden; }
    .feat-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .feat-body { padding: 2rem 2.2rem; display: flex; flex-direction: column; gap: .85rem; justify-content: center; }
    .feat-badges { display: flex; gap: .45rem; }
    .feat-title { font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 600; line-height: 1.1; }
    .feat-tagline { font-size: 1.05rem; color: var(--parchment-dim); font-style: italic; line-height: 1.55; }
    .feat-desc { font-family: var(--mono); font-size: .78rem; color: var(--rune); letter-spacing: .02em; }
    .feat-actions { display: flex; gap: .9rem; flex-wrap: wrap; margin-top: .3rem; }
    @media (max-width: 700px) { .feat-card { grid-template-columns: 1fr; } }
    .pillars { display: grid; grid-template-columns: 1fr; gap: 1.1rem; padding-bottom: 2rem; }
    @media (min-width: 800px){ .pillars { grid-template-columns: 1fr 1fr 1fr; } }
    .pillar { border: 1px solid var(--line); border-radius: 12px; padding: 1.6rem; background: var(--ink-2); }
    .pillar.accent { border-color: var(--ember-soft); }
    .pnum { color: var(--gild); font-size: .8rem; }
    .pillar h2 { font-size: 1.4rem; font-weight: 600; margin: .5rem 0 .6rem; }
    .pillar p { color: var(--parchment-dim); font-size: .98rem; margin-bottom: 1.1rem; }
    .plink { color: var(--ember); font-size: .8rem; }
    .about-strip { padding-top: 1rem; padding-bottom: 3rem; max-width: 760px; }
    .about-strip p { color: var(--parchment-dim); font-size: .98rem; line-height: 1.7; margin-bottom: .9rem; }
    .about-strip p:last-child { margin-bottom: 0; }
  </style>
</Base>
