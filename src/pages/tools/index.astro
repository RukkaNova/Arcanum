---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Tools — Free Utilities for AI Roleplayers | Arcanum"
  description="Free browser-based tools for AI RPG campaigns. No accounts, no data stored. Built for players running ChatGPT, Claude, and Gemini campaigns."
>
  <div class="wrap tools-page">
    <p class="eyebrow mono">// tools</p>
    <h1>Tools</h1>
    <p class="sub">Free browser utilities for AI roleplayers. No accounts. No data stored anywhere.</p>
    <div class="cards">
      <a class="tool-card" href="/tools/campaign-memory">
        <h2>Campaign Memory Tool</h2>
        <p>Track characters, plot threads, locations, and world facts across long campaigns. Hit Generate and paste the compression prompt into ChatGPT, Claude, or Gemini — get back a compact session memory block that keeps context coherent past turn 50.</p>
        <span class="badge mono">Free · Client-side only</span>
      </a>
    </div>
  </div>
  <style>
    .tools-page { padding: 3rem 1.25rem 5rem; }
    .eyebrow { color: var(--rune); font-size: .78rem; letter-spacing: .06em; margin-bottom: 1rem; }
    h1 { font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 600; margin-bottom: .5rem; }
    .sub { color: var(--parchment-dim); margin: 0 0 2.5rem; font-size: 1rem; }
    .cards { display: flex; flex-direction: column; gap: 1rem; max-width: 620px; }
    .tool-card {
      display: block;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1.6rem;
      background: var(--ink-2);
      color: var(--parchment);
      text-decoration: none;
      transition: border-color .15s;
    }
    .tool-card:hover { border-color: var(--ember); text-decoration: none; }
    .tool-card h2 { font-size: 1.25rem; font-weight: 600; margin-bottom: .5rem; }
    .tool-card p { color: var(--parchment-dim); font-size: .95rem; line-height: 1.75; margin-bottom: .9rem; }
    .badge { font-size: .72rem; color: var(--rune); }
  </style>
</Base>
