// ── first-message openers, keyed loosely by tone (assembled around the scenario) ──
var OPENERS = {
  warm: [
    '*{{char}} catches {{user}}\'s eye and, after a beat, decides to be the one who speaks first.* "You look like someone with a story and nowhere to tell it. I\'ve got time, and better company than whatever you were about to do instead. Sit."',
