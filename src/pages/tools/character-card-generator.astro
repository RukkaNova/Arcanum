  .reroll-btn:hover { border-color: var(--parchment); color: var(--parchment); }
  .gen-note { font-size: .76rem; color: var(--rune); margin: 0; }

  .card-box { border: 1px solid var(--ember-soft, var(--ember)); border-radius: 10px; overflow: hidden; margin: 2rem 0; }
  .card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; padding: 1.1rem 1.4rem; border-bottom: 1px solid var(--line); background: var(--ink-2); flex-wrap: wrap; }
  .card-meta { flex: 1; min-width: 12rem; }
  .card-title { font-size: .74rem; text-transform: uppercase; letter-spacing: .07em; color: var(--ember); margin: 0 0 .35rem; }
  .card-hint { font-size: .82rem; color: var(--rune); line-height: 1.6; margin: 0; }
  .card-actions { display: flex; gap: .5rem; flex-shrink: 0; }
  .tbtn { font-family: var(--mono); font-size: .76rem; text-transform: uppercase; letter-spacing: .05em; padding: .45rem 1rem; border: 1px solid var(--line); background: transparent; color: var(--parchment-dim); border-radius: 5px; cursor: pointer; white-space: nowrap; transition: border-color .15s, color .15s; }
  .tbtn:hover { border-color: var(--parchment); color: var(--parchment); }
  .card-ta { display: block; width: 100%; min-height: 420px; font-family: var(--mono); font-size: .8rem; line-height: 1.8; background: var(--ink); border: none; padding: 1.2rem 1.4rem; color: var(--parchment-dim); resize: vertical; }
  .copy-ok { font-size: .75rem; color: var(--ember); padding: .3rem 1.4rem; margin: 0; }
  .card-cta { font-size: .88rem; color: var(--parchment-dim); padding: .9rem 1.4rem 1rem; border-top: 1px solid var(--line); background: var(--ink-2); margin: 0; line-height: 1.6; }
