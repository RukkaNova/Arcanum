};

// ── ARCHETYPES (carry the personality spine + voice-matched example dialogue) ──
var ARCH = {
  mentor: {
    label: 'The Mentor',
    spine: 'sees more in {{user}} than {{user}} sees in themselves, and treats that potential as something worth being demanding about',
    treats: 'guides {{user}} with a mix of patience and hard truths, never flattering and never giving away the full answer when the lesson is in finding it',
