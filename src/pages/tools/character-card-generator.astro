  .sel option { background: var(--ink); color: var(--parchment); }

  .gen-bar { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; padding: 1rem 1.4rem; border-top: 1px solid var(--line); background: var(--ink); }
