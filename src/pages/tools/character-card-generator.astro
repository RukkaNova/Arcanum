  ],
  romantic: [
    '*{{char}} watches {{user}} a moment longer than strictly polite, then glances away as if caught.* "Sorry. You just — you have the look of someone I\'d regret not talking to. I\'m not usually this forward. Stay a minute anyway?"',
    '*A pause, careful, like {{char}} is choosing the words.* "I\'m bad at this part. The starting part. So I\'ll just say it plainly: I\'m glad it\'s you sitting there, and I\'d like the chance to find out why."'
  ],
  adventurous: [
    '*{{char}} is already moving, already half-grinning.* "Perfect timing — I was about to do something deeply ill-advised and I could use a second pair of hands. Or at least a witness. You in, or are you going to stand there looking sensible?"',
    '*{{char}} claps {{user}} on the shoulder like they\'ve known each other years.* "Right. No time for the polite version — there\'s a thing, it\'s happening now, and you turning up means you\'re part of it whether you meant to be or not. Keep up."'
  ]
};

// ── assembly ──
function buildCard(opts){
  var genre = opts.genre==='any' ? pick(['fantasy','scifi','cyberpunk','modern','horror','postapoc']) : opts.genre;
  var archKey = opts.arch==='any' ? pick(Object.keys(ARCH)) : opts.arch;
  var gender = opts.gender==='any' ? pick(['female','male','nonbinary']) : opts.gender;
  var tone = opts.tone==='any' ? pick(['warm','dark','romantic','adventurous']) : opts.tone;

  var arch = ARCH[archKey];
  var poolKey = NAMEPOOL[genre];
  var first = pick(FIRST[poolKey][gender]);
  var name = Math.random() < 0.55 ? first + ' ' + pick(EPITHET[genre]) : first;

  var quirks = sample(QUIRKS, 2);
  var speech = pick(SPEECH);
  var flaw = pick(FLAWS);
  var motive = pick(MOTIVE);
  var scenario = pick(SCENARIO[genre]);
  var opener = pick(OPENERS[tone]);
  var exLines = sample(arch.ex, 2);

  // personality paragraph
  var personality =
    cap('{{char}} ' + arch.spine + '. ') +
    cap('{{char}} ' + arch.treats + '. ') +
    cap('{{char}} ' + quirks[0] + ', and ' + quirks[1] + '. ') +
    speech + ' ' +
    'Underneath it all, {{char}} ' + motive + '. ' +
    'Hard limit: ' + flaw;

  var exampleBlock = exLines.map(function(p){
    return '{{user}}: ' + p[0] + '\n{{char}}: ' + p[1];
  }).join('\n\n');

  var card =
    'Name: ' + name + '\n' +
    'Summary: ' + arch.tagline + '.\n\n' +
    'Personality:\n' + personality + '\n\n' +
    'Scenario:\n' + scenario + '\n\n' +
    'First Message:\n' + opener + '\n\n' +
    'Example Dialogue:\n' + exampleBlock + '\n';

  var summary = arch.label + ' · ' + cap(genre==='postapoc'?'post-apocalyptic':(genre==='scifi'?'sci-fi':genre)) + ' · ' + cap(tone);
  return { card: card, name: name, summary: summary };
}

// ── UI ──
var noteEl = document.getElementById('gen-note');
var rerollBtn = document.getElementById('reroll-btn');
var lastName = 'character-card';

function readOpts(){
  return {
    genre: document.getElementById('f-genre').value,
    arch:  document.getElementById('f-archetype').value,
    gender:document.getElementById('f-gender').value,
    tone:  document.getElementById('f-tone').value
  };
}
function generate(){
  var out = buildCard(readOpts());
  document.getElementById('card-out').value = out.card;
  document.getElementById('card-summary').textContent = out.summary;
  lastName = out.name.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'') || 'character-card';
  var box = document.getElementById('card-box');
  box.classList.remove('hidden');
  rerollBtn.classList.remove('hidden');
  noteEl.textContent='';
}
document.getElementById('gen-btn').addEventListener('click', function(){
  generate();
  setTimeout(function(){ document.getElementById('card-box').scrollIntoView({behavior:'smooth',block:'start'}); }, 60);
});
rerollBtn.addEventListener('click', generate);

// copy
document.getElementById('copy-btn').addEventListener('click', function(){
  var text = document.getElementById('card-out').value;
  if (navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(showCopied).catch(fallbackCopy);
  } else { fallbackCopy(); }
});
function fallbackCopy(){
  var ta=document.getElementById('card-out'); ta.select();
  try{ document.execCommand('copy'); showCopied(); }catch(e){}
}
function showCopied(){
  var el=document.getElementById('copy-ok');
  el.classList.remove('hidden');
  setTimeout(function(){ el.classList.add('hidden'); }, 2800);
}

// download
document.getElementById('dl-btn').addEventListener('click', function(){
  var text = document.getElementById('card-out').value;
  var blob = new Blob([text], {type:'text/plain'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url; a.download = lastName + '.txt';
  document.body.appendChild(a); a.click();
  document.body.removeChild(a); URL.revokeObjectURL(url);
});
</script>

