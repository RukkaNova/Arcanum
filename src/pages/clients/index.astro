---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
const clients=(await getCollection('clients')).sort((a,b)=>(b.data.rating??0)-(a.data.rating??0));
const stars=(r)=>r?'★'.repeat(Math.round(r))+'☆'.repeat(5-Math.round(r)):'';
---
<Base title="Best LLM Roleplay Platforms & Clients Reviewed | Arcanum" description="Honest reviews of every AI roleplay client — Janitor, Friends & Fables, AI Dungeon, SillyTavern and more. See which LLM gaming platform is actually worth your time.">
  <div class="wrap browse">
    <h1>Clients</h1>
    <p class="sub">Every roleplay platform, reviewed. Find the one worth your time — or skip them all and play on your own AI.</p>
    <div class="list">
      {clients.map(c=>(
        <a class="row" href={`/clients/${c.id}`}>
          <div class="thumb">{c.data.cover && <img src={c.data.cover} alt={c.data.title} loading="lazy" width="800" height="450"/>}</div>
          <div class="info">
            <div class="rowtop">
              <h2>{c.data.title}</h2>
              <span class="pricing token">{c.data.pricing}</span>
            </div>
            <p class="tag">{c.data.tagline}</p>
            {c.data.bestFor && <p class="bestfor mono">Best for: {c.data.bestFor}</p>}
            {c.data.rating && <span class="rating mono">{stars(c.data.rating)} {c.data.rating}/5</span>}
          </div>
        </a>
      ))}
    </div>
  </div>
  <style>
    .browse{padding:3rem 1.25rem 2rem;}
    h1{font-size:clamp(2rem,5vw,3rem);font-weight:600;}
    .sub{color:var(--parchment-dim);margin:.4rem 0 2rem;max-width:40rem;}
    .list{display:flex;flex-direction:column;gap:1rem;}
    .row{display:grid;grid-template-columns:1fr;gap:0;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--ink-2);color:var(--parchment);transition:border-color .18s;}
    @media(min-width:640px){.row{grid-template-columns:240px 1fr;}}
    .row:hover{border-color:var(--ember);text-decoration:none;}
    .thumb{background:var(--ink);overflow:hidden;aspect-ratio:16/9;}
    .thumb img{width:100%;height:100%;object-fit:contain;display:block;}
    .info{padding:1.2rem 1.4rem;}
    .rowtop{display:flex;justify-content:space-between;align-items:center;gap:1rem;}
    .info h2{font-size:1.4rem;font-weight:600;}
    .pricing{text-transform:uppercase;}
    .tag{color:var(--parchment-dim);margin:.4rem 0;}
    .bestfor{font-size:.78rem;color:var(--rune);margin:.5rem 0;}
    .rating{color:var(--gild);font-size:.82rem;}
  </style>
</Base>
