---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
export async function getStaticPaths(){
  const c=await getCollection('clients');
  return c.map(x=>({params:{id:x.id},props:{client:x}}));
}
import Stars from '../../components/Stars.astro';
import VideoFacade from '../../components/VideoFacade.astro';
const { client }=Astro.props; const { Content }=await render(client); const d=client.data;
const metaDesc=(()=>{if(!d.bestFor)return d.tagline;const full=`${d.tagline} Best for: ${d.bestFor}`;return full.length<=160?full:d.tagline;})();
const appLd={'@context':'https://schema.org','@type':'SoftwareApplication',name:d.title,applicationCategory:'GameApplication',description:d.tagline,...(d.rating&&{aggregateRating:{'@type':'AggregateRating',ratingValue:d.rating,ratingCount:1,bestRating:5}})};
const ORIGIN='https://arcanumrpgs.com';
const videoLd=d.video
  ?{'@context':'https://schema.org','@type':'VideoObject',name:d.video.title,description:d.video.description??d.tagline,thumbnailUrl:[ORIGIN+d.video.poster],uploadDate:(d.video.uploadDate??d.updated).toISOString(),...(d.video.duration&&{duration:d.video.duration}),embedUrl:`https://www.youtube.com/embed/${d.video.id}`,contentUrl:`https://youtu.be/${d.video.id}`}
  :null;
const jsonLd=videoLd?[appLd,videoLd]:appLd;
const fmtDur=(iso)=>{const m=iso?.match(/PT(?:(\d+)M)?(?:(\d+)S)?/);if(!m)return null;return `${+(m[1]||0)}:${String(+(m[2]||0)).padStart(2,'0')}`;};
const videoCaption=d.video?(d.video.duration?`Video review · ${fmtDur(d.video.duration)}`:'Video review'):null;
---
<Base title={`${d.title} Review — LLM Roleplay Client | Arcanum`} description={metaDesc} type="article" jsonLd={jsonLd}>
  <article class="wrap game">
    <a class="back mono" href="/clients">← all clients</a>
    {d.cover && <div class="hero-img"><img src={d.cover} alt={d.title} width="800" height="450"/></div>}
    <div class="badges"><span class="token">{d.pricing}</span>{d.rating && <span class="rating mono"><Stars rating={d.rating}/> {d.rating}/5</span>}</div>
    <h1>{d.title}</h1>
    <p class="tagline">{d.tagline}</p>
    <div class="meta-row mono">
      {d.bestFor && <span>Best for: {d.bestFor}</span>}
      <span class="reviewed">Last reviewed: {d.updated.toLocaleDateString('en-US',{year:'numeric',month:'long'})}</span>
    </div>
    <div class="actions">
      {d.siteUrl && <a class="launch" href={d.siteUrl} target="_blank" rel="noopener">Visit {d.title} ↗</a>}
      {d.reviewSlug && <a class="review" href={`/blog/${d.reviewSlug}`}>Full review →</a>}
    </div>
    {d.video && <VideoFacade id={d.video.id} poster={d.video.poster} title={d.video.title} caption={videoCaption} />}
    <div class="prose"><Content/></div>
  </article>
  <style>
    .game{padding:2rem 1.25rem 3rem;max-width:760px;}
    .back{color:var(--parchment-dim);font-size:.8rem;}
    .hero-img{margin:1.4rem 0;border:1px solid var(--line);border-radius:12px;overflow:hidden;aspect-ratio:16/9;}
    .hero-img img{width:100%;height:100%;object-fit:cover;display:block;}
    .badges{display:flex;gap:.6rem;align-items:center;margin:.6rem 0 1rem;}
    .rating{color:var(--gild);font-size:.85rem;}
    h1{font-size:clamp(2.2rem,5vw,3.2rem);font-weight:600;}
    .tagline{font-size:1.2rem;color:var(--parchment-dim);font-style:italic;margin:.7rem 0 .6rem;}
    .meta-row{font-size:.8rem;color:var(--rune);display:flex;gap:.8rem;flex-wrap:wrap;margin-bottom:.2rem;}
    .reviewed{color:var(--rune);}
    .actions{display:flex;gap:1rem;flex-wrap:wrap;margin:1.6rem 0;}
    .launch{font-family:var(--mono);font-size:.85rem;background:var(--ember);color:var(--ink);padding:.7rem 1.3rem;border-radius:7px;font-weight:600;}
    .launch:hover{text-decoration:none;filter:brightness(1.08);}
    .review{font-family:var(--mono);font-size:.85rem;border:1px solid var(--line);color:var(--parchment);padding:.7rem 1.3rem;border-radius:7px;}
    .review:hover{border-color:var(--ember);color:var(--ember);text-decoration:none;}
    .prose{margin-top:1.5rem;border-top:1px solid var(--line);padding-top:1.8rem;}
    .prose :global(p){margin-bottom:1rem;}
  </style>
</Base>
