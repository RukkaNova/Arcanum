---
import Newsletter from '../components/Newsletter.astro';
// Base layout — owns ALL the per-page SEO. This is the discoverability core.
// Every page passes title/description; canonical + OG + Twitter are derived.
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: object; // optional structured data for rich/AI-citation eligibility
  noindex?: boolean;
}
const { title, description, image, type = 'website', jsonLd, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
// Every page gets a share card: its own art if passed, else the site-wide default.
const ogImage = new URL(image ?? '/img/arcanum-og.webp', Astro.site);
// External surfaces say "Arcanum RPGs" — plain "Arcanum" collides with the
// 2001 Troika CRPG and other tabletop brands in search.
const SITE = 'Arcanum RPGs';
const path = Astro.url.pathname;
const navItems = [
  { href: '/games', label: 'Games' },
  { href: '/clients', label: 'Clients' },
  { href: '/arcanum-games', label: 'Arcanum Originals' },
  { href: '/blog', label: 'Codex' },
  { href: '/tools', label: 'AI RPG Tools' },
  { href: '/about', label: 'About' },
];
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, follow" />}

  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#14110f" />

  <!-- Display font: self-hosted latin subset, font-display:optional (no CLS, never swaps after first paint) -->
  <link rel="preload" href="/fonts/cormorant-garamond-600-latin.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter -->
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Arcanum RPGs — The Codex" href="/rss.xml" />

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />}

  <style is:global>
    @font-face {
      font-family: "Cormorant Garamond";
      font-style: normal;
      font-weight: 600;
      font-display: optional;
      src: url("/fonts/cormorant-garamond-600-latin.woff2") format("woff2");
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    :root {
      --ink: #14110f;          /* deep near-black brown — the void you summon into */
      --ink-2: #1d1916;
      --parchment: #e8ddc7;    /* aged page */
      --parchment-dim: #b9ad95;
      --ember: #d96f32;        /* the single warm accent — lamp/ember, NOT terracotta-cream */
      --ember-soft: #3a2418;
      --gild: #c9a14a;         /* gilt detail, used sparingly */
      --line: #2e2823;
      --rune: #6f8f86;         /* cool counter-accent for "machine" elements */
      --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, serif;
      --mono: ui-monospace, "SF Mono", "Cascadia Code", "Roboto Mono", Menlo, monospace;
      --display: "Cormorant Garamond", "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; scroll-padding-top: 4.5rem; }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
    body {
      background: var(--ink);
      color: var(--parchment);
      font-family: var(--serif);
      line-height: 1.6;
      font-size: 18px;
      -webkit-font-smoothing: antialiased;
    }
    /* Display face for headings + brand only — body stays on the system serif */
    h1, h2, h3 { font-family: var(--display); }
    a { color: var(--ember); text-decoration: none; }
    a:hover { text-decoration: underline; text-underline-offset: 3px; }
    /* inline links in running body copy need a non-color cue (WCAG 1.4.1) — nav/button/UI links keep their own affordance */
    p a { text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--ember) 45%, transparent); text-underline-offset: 2px; }
    p a:hover { text-decoration-color: var(--ember); }
    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 1.25rem; }
    .mono { font-family: var(--mono); }
    /* the "machine tag" — platform/genre chips read as terminal tokens */
    .token {
      font-family: var(--mono); font-size: .72rem; letter-spacing: .04em;
      text-transform: uppercase; color: var(--rune);
      border: 1px solid var(--line); border-radius: 4px;
      padding: .18rem .5rem; display: inline-block; white-space: nowrap;
    }
    .token.is-platform { color: var(--ember); border-color: var(--ember-soft); }
    :focus-visible { outline: 2px solid var(--ember); outline-offset: 2px; }
    header.site, footer.site { border-color: var(--line); }
    header.site {
      border-bottom: 1px solid var(--line); position: sticky; top: 0;
      background: color-mix(in srgb, var(--ink) 88%, transparent);
      backdrop-filter: blur(8px); z-index: 50;
    }
    .nav { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .5rem; padding: .9rem 0; }
    .brand { font-family: var(--display); font-size: 1.5rem; font-weight: 600; color: var(--parchment); letter-spacing: .01em; }
    .brand b { color: var(--ember); font-weight: 600; }
    /* mobile-first nav — JS-free disclosure via the checkbox hack (no layout shift, no script) */
    .nav-toggle { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
    .nav-burger { display: inline-flex; flex-direction: column; justify-content: center; gap: 5px; width: 44px; height: 38px; padding: 0 9px; margin-left: auto; cursor: pointer; border: 1px solid var(--line); border-radius: 7px; }
    .nav-burger span { display: block; height: 2px; width: 100%; background: var(--parchment-dim); transition: background .18s; }
    .nav-burger:hover span { background: var(--ember); }
    .nav-toggle:focus-visible + .nav-burger { outline: 2px solid var(--ember); outline-offset: 2px; }
    .nav-links { display: none; flex-basis: 100%; flex-direction: column; font-family: var(--mono); font-size: .82rem; text-transform: uppercase; letter-spacing: .08em; }
    .nav-toggle:checked ~ .nav-links { display: flex; }
    .nav-links a { color: var(--parchment-dim); padding: .75rem .2rem; border-top: 1px solid var(--line); }
    .nav-links a:hover { color: var(--ember); text-decoration: none; }
    .nav-links a[aria-current="page"] { color: var(--ember); }
    @media (min-width: 760px) {
      .nav { flex-wrap: nowrap; }
      .nav-toggle, .nav-burger { display: none; }
      .nav-links { display: flex !important; flex-basis: auto; flex-direction: row; gap: 1.4rem; font-size: .8rem; }
      .nav-links a { padding: 0; border-top: none; }
    }
    footer.site { border-top: 1px solid var(--line); margin-top: 5rem; padding: 2.5rem 0; color: var(--parchment-dim); font-size: .85rem; }
    /* prose tables — used in client/game/release/blog markdown content */
    .prose table { width: 100%; border-collapse: collapse; margin: 1.6rem 0; font-size: .88rem; display: block; overflow-x: auto; }
    .prose thead tr { background: var(--ink-2); border-bottom: 2px solid var(--ember-soft); }
    .prose th { font-family: var(--mono); font-size: .72rem; text-transform: uppercase; letter-spacing: .07em; color: var(--rune); padding: .65rem 1rem; text-align: left; white-space: nowrap; }
    .prose td { padding: .65rem 1rem; border-bottom: 1px solid var(--line); color: var(--parchment-dim); vertical-align: top; line-height: 1.5; }
    .prose tr:last-child td { border-bottom: none; }
    .prose tbody tr:hover td { background: color-mix(in srgb, var(--ink-2) 60%, transparent); }
    .prose h2 { font-size: 1.6rem; font-weight: 600; letter-spacing: -.01em; margin: 2.6rem 0 .8rem; color: var(--parchment); }
    .prose h3 { font-size: 1.25rem; font-weight: 600; margin: 1.9rem 0 .5rem; color: var(--parchment); }
    .prose hr { border: none; height: 1px; background: var(--line); margin: 2.5rem 0; }
    .prose strong { color: var(--parchment); }
    /* persistent (subtle) underline on in-content links — affordance + WCAG, brightens on hover */
    .prose a { text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--ember) 45%, transparent); text-underline-offset: 2px; }
    .prose a:hover { text-decoration-color: var(--ember); }
    .prose ul, .prose ol { padding-left: 1.4rem; margin-bottom: 1rem; }
    .prose li { margin-bottom: .35rem; color: var(--parchment-dim); }
    .footer-inner { display: flex; flex-direction: column; gap: .9rem; }
    .footer-legal { font-family: var(--mono); font-size: .75rem; color: var(--parchment-dim); }
    .footer-legal a { color: var(--parchment-dim); }
    .footer-legal a:hover { color: var(--ember); text-decoration: none; }
    .footer-legal .sep { margin: 0 .5rem; opacity: .4; }
    .footer-kofi { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .footer-kofi span { color: var(--parchment-dim); font-size: .85rem; }
    .kofi-link { font-family: var(--mono); font-size: .78rem; letter-spacing: .04em; text-transform: uppercase; color: var(--gild); border: 1px solid var(--gild); padding: .4rem 1rem; border-radius: 6px; transition: background .18s, color .18s; white-space: nowrap; }
    .kofi-link:hover { background: var(--gild); color: var(--ink); text-decoration: none; }
    .footer-devs { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .footer-devs span { color: var(--parchment-dim); font-size: .85rem; }
    .devs-link { font-family: var(--mono); font-size: .78rem; letter-spacing: .04em; text-transform: uppercase; color: var(--rune); border: 1px solid var(--rune); padding: .4rem 1rem; border-radius: 6px; transition: background .18s, color .18s; white-space: nowrap; }
    .devs-link:hover { background: var(--rune); color: var(--ink); text-decoration: none; }
  </style>
</head>
<body>
  <header class="site">
    <div class="wrap nav">
      <a href="/" class="brand" style="text-decoration:none">Arc<b>a</b>num</a>
      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation menu" />
      <label for="nav-toggle" class="nav-burger" aria-hidden="true"><span></span><span></span><span></span></label>
      <nav class="nav-links" aria-label="Primary">
        {navItems.map(item => (
          <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
        ))}
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site">
    <div class="wrap footer-inner">
      <p>Arcanum — the directory for AI-run text worlds. Games run on your own ChatGPT, Claude, or Gemini.</p>
      <div class="footer-kofi">
        <span>Every world we release is free to play. If we earned it:</span>
        <a href="https://ko-fi.com/arcanumrpgs" target="_blank" rel="noopener" class="kofi-link">☕ Buy me a coffee</a>
      </div>
      <div class="footer-devs">
        <span>Want to talk shop or share a campaign?</span>
        <a href="https://discord.gg/b4DcTeBA8" target="_blank" rel="noopener" class="devs-link">Join our Discord →</a>
      </div>
      <div class="footer-devs">
        <span>Building an AI RPG platform?</span>
        <a href="/developers" class="devs-link">Work with Arcanum →</a>
      </div>
      <Newsletter variant="footer" />
      <div class="footer-legal">
        <a href="/contact">Contact</a>
        <span class="sep">·</span>
        <a href="/privacy">Privacy Policy</a>
        <span class="sep">·</span>
        <a href="/terms">Terms of Use</a>
        <span class="sep">·</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </footer>
</body>
</html>
